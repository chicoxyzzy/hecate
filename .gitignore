.env
# Auto-generated on first run by internal/bootstrap. Holds the AES-GCM
# control-plane key + admin bearer token, mode 0600. Default location is
# the repo root (GATEWAY_DATA_DIR=.), so this matters — *never* commit it.
*.bootstrap.json
.gocache/
.gomodcache/
.gopath/
# Built binary produced by `make build`. Anchored to the repo root so a
# package or test happening to be named "gateway" elsewhere isn't ignored.
/gateway
node_modules/
ui/node_modules/
e2e/local-ollama-*.log
ui/dist/*
!ui/dist/.gitkeep
ui/*.tsbuildinfo
ui/test-results/
ui/playwright-report/
ui/coverage/
coverage.out
