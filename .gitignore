.env
.claude/
# Default GATEWAY_DATA_DIR for local dev. Holds the auto-generated
# bootstrap file (AES-GCM control-plane key + admin bearer token, mode
# 0600). Never commit it.
.data/
.gocache/
.gomodcache/
.gopath/
# Built binary produced by `make build`. Anchored to the repo root so a
# package or test happening to be named "hecate" elsewhere isn't ignored.
/hecate
node_modules/
ui/node_modules/
e2e/local-ollama-*.log
ui/dist/*
!ui/dist/.gitkeep
ui/*.tsbuildinfo
ui/test-results/
ui/playwright-report/
ui/coverage/
coverage.out
