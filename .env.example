# Hecate runtime
# Copy to `.env` and keep your real secrets there. `make dev` sources `.env` directly.

# Server
GATEWAY_ADDRESS=:8080
GATEWAY_AUTH_TOKEN=

# Control plane
# Use `none` for local-only startup.
# Use `file`, `redis`, or `postgres` when you want persisted control-plane state.
GATEWAY_CONTROL_PLANE_BACKEND=none
GATEWAY_CONTROL_PLANE_KEY=control-plane
GATEWAY_CONTROL_PLANE_SECRET_KEY=

# Providers
# Minimal cloud setup:
#   PROVIDER_OPENAI_API_KEY=your_api_key_here
#
# All built-in provider presets known by Hecate today:
#   GATEWAY_PROVIDERS=openai,anthropic,groq,gemini,ollama,lmstudio,localai,llamacpp
#
# Local + cloud setup:
#   PROVIDER_OPENAI_API_KEY=your_api_key_here
#   GATEWAY_PROVIDERS=openai,ollama
#
# Anthropic setup:
#   PROVIDER_ANTHROPIC_API_KEY=your_api_key_here
#
# Real runtime support today:
#   - OpenAI-compatible chat+model-discovery providers
#   - Anthropic native Messages API providers
#
# Built-in preset names with defaults:
#   openai, anthropic, groq, gemini, ollama, lmstudio, localai, llamacpp
#
# In practice this means:
#   - `openai`, `groq`, `gemini`, `ollama`, `lmstudio`, `localai`, and `llamacpp`
#     all use the OpenAI-compatible provider path
#   - `anthropic` uses the native Anthropic provider path
#
# `GATEWAY_PROVIDERS` is optional. When omitted, Hecate can infer enabled providers
# from core bootstrap envs such as `PROVIDER_<NAME>_API_KEY`,
# `PROVIDER_<NAME>_BASE_URL`, or `PROVIDER_<NAME>_PROTOCOL`.
#
# You can also define an additional provider name not listed above by setting
# `PROVIDER_<NAME>_BASE_URL`. Unknown names default to the OpenAI-compatible
# protocol unless you explicitly set `PROVIDER_<NAME>_PROTOCOL`.
#
# Set `GATEWAY_PROVIDERS` explicitly when you want to enable a built-in preset
# using its defaults. This is the shortest way to enable local runtimes.
#
# Documented core provider overrides:
#   API_KEY, BASE_URL, DEFAULT_MODEL
#
# Advanced overrides such as `PROTOCOL`, `API_VERSION`, `TIMEOUT`, `MODELS`,
# or `ALLOW_ANY_MODEL` are still supported, but most setups should not need them.
# GATEWAY_PROVIDERS=openai,anthropic,groq,gemini,ollama,lmstudio,localai,llamacpp
GATEWAY_DEFAULT_MODEL=gpt-5.4-mini

PROVIDER_OPENAI_API_KEY=your_api_key_here

# Local provider defaults:
#   ollama   -> http://127.0.0.1:11434/v1
#   lmstudio -> http://127.0.0.1:1234/v1
#   localai  -> http://127.0.0.1:8080/v1
#   llamacpp -> http://127.0.0.1:8080/v1
#
# LocalAI and llama.cpp share the same default URL because both commonly expose
# OpenAI-compatible servers on port 8080. Enable only the one you actually run,
# or override BASE_URL so each configured provider points to a unique endpoint.
# PROVIDER_OLLAMA_DEFAULT_MODEL=llama3.1:8b
# PROVIDER_ANTHROPIC_API_KEY=your_api_key_here
# PROVIDER_GROQ_API_KEY=your_api_key_here
# PROVIDER_GEMINI_API_KEY=your_api_key_here

# Provider execution
GATEWAY_PROVIDER_MAX_ATTEMPTS=2
GATEWAY_PROVIDER_RETRY_BACKOFF=200ms
GATEWAY_PROVIDER_FAILOVER_ENABLED=true
GATEWAY_PROVIDER_HEALTH_FAILURE_THRESHOLD=3
GATEWAY_PROVIDER_HEALTH_COOLDOWN=30s

# Exact cache
GATEWAY_CACHE_BACKEND=memory
GATEWAY_CACHE_TTL=5m

# Semantic cache
GATEWAY_SEMANTIC_CACHE_ENABLED=false
GATEWAY_SEMANTIC_CACHE_BACKEND=memory

# Budgeting / balance tracking
GATEWAY_BUDGET_BACKEND=memory
GATEWAY_BUDGET_KEY=global
GATEWAY_BUDGET_SCOPE=global
GATEWAY_MAX_BUDGET_MICROS_USD=5000000

# Retention
GATEWAY_RETENTION_ENABLED=false
GATEWAY_RETENTION_INTERVAL=15m

# OpenTelemetry
GATEWAY_OTEL_SERVICE_NAME=hecate-gateway
GATEWAY_OTEL_TRACES_ENABLED=false
GATEWAY_OTEL_TRACES_ENDPOINT=
GATEWAY_OTEL_METRICS_ENABLED=false
GATEWAY_OTEL_METRICS_ENDPOINT=
GATEWAY_OTEL_LOGS_ENABLED=false
GATEWAY_OTEL_LOGS_ENDPOINT=

# Redis
REDIS_ADDRESS=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=agent-runtime
REDIS_TIMEOUT=3s

# Postgres
POSTGRES_DSN=
POSTGRES_SCHEMA=public
POSTGRES_TABLE_PREFIX=hecate
POSTGRES_MAX_OPEN_CONNS=10
POSTGRES_MAX_IDLE_CONNS=5

# Logging
LOG_LEVEL=INFO
