# Hecate runtime
# Copy to `.env` and keep your real secrets there. `make dev` sources `.env` directly.

# Server
GATEWAY_ADDRESS=:8080
GATEWAY_AUTH_TOKEN=

# Control plane
# Use `none` for local-only startup.
# Use `file`, `redis`, or `postgres` when you want persisted control-plane state.
GATEWAY_CONTROL_PLANE_BACKEND=none
GATEWAY_CONTROL_PLANE_FILE=
GATEWAY_CONTROL_PLANE_KEY=control-plane
GATEWAY_CONTROL_PLANE_SECRET_KEY=

# Providers
# Provider bootstrap is intentionally small. Hecate auto-discovers providers
# from `GATEWAY_PROVIDERS` and from explicit `PROVIDER_<NAME>_*` variables.
#
# Built-in names:
#   openai, anthropic, groq, gemini, ollama, lmstudio, localai, llamacpp
#
# Runtime support today:
#   - OpenAI-compatible chat + /v1/models discovery
#   - Anthropic native Messages API + /v1/models discovery
#
# Model lists are not configured in env. Hecate discovers provider catalogs
# from provider APIs and falls back to DEFAULT_MODEL when discovery is unavailable.
#
# Enable all built-ins explicitly if you want to see every preset at startup.
# GATEWAY_PROVIDERS=openai,anthropic,groq,gemini,ollama,lmstudio,localai,llamacpp
GATEWAY_DEFAULT_MODEL=gpt-5.4-mini

# Cloud providers
PROVIDER_OPENAI_API_KEY=your_api_key_here
# PROVIDER_OPENAI_DEFAULT_MODEL=gpt-5.4-mini

# PROVIDER_ANTHROPIC_API_KEY=your_api_key_here
# PROVIDER_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# PROVIDER_GROQ_API_KEY=your_api_key_here
# PROVIDER_GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# PROVIDER_GEMINI_API_KEY=your_api_key_here
# PROVIDER_GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Local providers
# Set BASE_URL to enable a local runtime when `GATEWAY_PROVIDERS` is omitted.
PROVIDER_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# PROVIDER_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
# PROVIDER_LOCALAI_BASE_URL=http://127.0.0.1:8080/v1
# PROVIDER_LLAMACPP_BASE_URL=http://127.0.0.1:8080/v1

# Custom provider core overrides
# PROVIDER_CUSTOM_NAME=custom
# PROVIDER_CUSTOM_KIND=cloud
# PROVIDER_CUSTOM_PROTOCOL=openai
# PROVIDER_CUSTOM_BASE_URL=https://example.com/v1
# PROVIDER_CUSTOM_API_KEY=your_api_key_here
# PROVIDER_CUSTOM_DEFAULT_MODEL=
# PROVIDER_CUSTOM_API_VERSION=
# PROVIDER_CUSTOM_TIMEOUT=30s

# Provider execution
GATEWAY_PROVIDER_MAX_ATTEMPTS=2
GATEWAY_PROVIDER_RETRY_BACKOFF=200ms
GATEWAY_PROVIDER_FAILOVER_ENABLED=true
GATEWAY_PROVIDER_HEALTH_FAILURE_THRESHOLD=3
GATEWAY_PROVIDER_HEALTH_COOLDOWN=30s

# Chat sessions
GATEWAY_CHAT_SESSIONS_BACKEND=memory
GATEWAY_CHAT_SESSIONS_FILE=
GATEWAY_CHAT_SESSIONS_KEY=chat-sessions
GATEWAY_CHAT_SESSIONS_LIMIT=50

# Task runtime
# Use `postgres` for durable task/run/step/artifact/approval/event state.
GATEWAY_TASKS_BACKEND=memory
# Comma-separated approval classes: shell_exec,git_exec,file_write,network_egress
GATEWAY_TASK_APPROVAL_POLICIES=shell_exec
GATEWAY_TASK_QUEUE_WORKERS=1
GATEWAY_TASK_QUEUE_BUFFER=128
# 0 means unlimited.
GATEWAY_TASK_MAX_CONCURRENT_PER_TENANT=0

# Exact cache
GATEWAY_CACHE_BACKEND=memory
GATEWAY_CACHE_TTL=5m

# Semantic cache
GATEWAY_SEMANTIC_CACHE_ENABLED=false
GATEWAY_SEMANTIC_CACHE_BACKEND=memory
GATEWAY_SEMANTIC_CACHE_TTL=24h
GATEWAY_SEMANTIC_CACHE_MIN_SIMILARITY=0.92
GATEWAY_SEMANTIC_CACHE_MAX_ENTRIES=10000
GATEWAY_SEMANTIC_CACHE_MAX_TEXT_CHARS=8000
GATEWAY_SEMANTIC_CACHE_EMBEDDER=local_simple
GATEWAY_SEMANTIC_CACHE_EMBEDDER_PROVIDER=
GATEWAY_SEMANTIC_CACHE_EMBEDDER_MODEL=
GATEWAY_SEMANTIC_CACHE_EMBEDDER_BASE_URL=
GATEWAY_SEMANTIC_CACHE_EMBEDDER_API_KEY=
GATEWAY_SEMANTIC_CACHE_EMBEDDER_TIMEOUT=30s

# Governance / balance tracking
GATEWAY_DENY_ALL=false
GATEWAY_MAX_PROMPT_TOKENS=64000
GATEWAY_MAX_BUDGET_MICROS_USD=5000000
GATEWAY_MODEL_REWRITE_TO=
GATEWAY_BUDGET_BACKEND=memory
GATEWAY_BUDGET_KEY=global
GATEWAY_BUDGET_SCOPE=global
GATEWAY_BUDGET_TENANT_FALLBACK=anonymous
GATEWAY_ROUTE_MODE=any
GATEWAY_ALLOWED_PROVIDERS=
GATEWAY_DENIED_PROVIDERS=
GATEWAY_ALLOWED_MODELS=
GATEWAY_DENIED_MODELS=
GATEWAY_ALLOWED_PROVIDER_KINDS=
GATEWAY_BUDGET_WARNING_THRESHOLDS=50,80,95
GATEWAY_BUDGET_HISTORY_LIMIT=20

# Retention
GATEWAY_RETENTION_ENABLED=false
GATEWAY_RETENTION_INTERVAL=15m
GATEWAY_RETENTION_TRACES_MAX_AGE=24h
GATEWAY_RETENTION_TRACES_MAX_COUNT=2000
GATEWAY_RETENTION_BUDGET_EVENTS_MAX_AGE=720h
GATEWAY_RETENTION_BUDGET_EVENTS_MAX_COUNT=200
GATEWAY_RETENTION_AUDIT_EVENTS_MAX_AGE=720h
GATEWAY_RETENTION_AUDIT_EVENTS_MAX_COUNT=500
GATEWAY_RETENTION_EXACT_CACHE_MAX_AGE=24h
GATEWAY_RETENTION_EXACT_CACHE_MAX_COUNT=10000
GATEWAY_RETENTION_SEMANTIC_CACHE_MAX_AGE=168h
GATEWAY_RETENTION_SEMANTIC_CACHE_MAX_COUNT=10000

# OpenTelemetry
GATEWAY_OTEL_SERVICE_NAME=hecate-gateway
GATEWAY_OTEL_TRACES_ENABLED=false
GATEWAY_OTEL_TRACES_ENDPOINT=
GATEWAY_OTEL_TRACES_HEADERS=
GATEWAY_OTEL_TRACES_TIMEOUT=5s
GATEWAY_OTEL_METRICS_ENABLED=false
GATEWAY_OTEL_METRICS_ENDPOINT=
GATEWAY_OTEL_METRICS_HEADERS=
GATEWAY_OTEL_METRICS_TIMEOUT=5s
GATEWAY_OTEL_METRICS_INTERVAL=30s
GATEWAY_OTEL_LOGS_ENABLED=false
GATEWAY_OTEL_LOGS_ENDPOINT=
GATEWAY_OTEL_LOGS_HEADERS=
GATEWAY_OTEL_LOGS_TIMEOUT=5s

# Redis
REDIS_ADDRESS=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=agent-runtime
REDIS_TIMEOUT=3s

# Postgres
POSTGRES_DSN=
POSTGRES_SCHEMA=public
POSTGRES_TABLE_PREFIX=hecate
POSTGRES_MAX_OPEN_CONNS=10
POSTGRES_MAX_IDLE_CONNS=5

# Logging
LOG_LEVEL=INFO
